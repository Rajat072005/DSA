class Solution {
public:
    bool checkOnesSegment(string s) {
        //if(s.size() == 1)return true;
        int ans = 0;
        stack<int>st;
        for(int i = 0 ; i<s.size() ; i++){
            if(s[i] == '1')st.push(s[i] - '0');
            else{
                if(st.size()>=1)ans++;
                while(!st.empty()){
                    st.pop();
                }
            }
        }
        if(!st.empty())ans++;
        return (ans == 1 ? true : false);

    }
};
